{block title}Nový test{/block}
{block content}
<section class="test-start-card">
    <div class="test-start-icon">⚽</div>
    <div>
        <span class="eyebrow">Příprava rozhodčího</span>
        <h1>Nový test</h1>
        <p>Vyberte počet otázek a časový limit. Otázky budou náhodně vybrány z databáze {$questionCount|number} aktivních otázek.</p>
    </div>
    {control setupForm}
</section>
{/block}
