<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Moderní fotbalové testy pro rozhodčí">
    <title>{ifset title}{include title} · {/ifset}FotbalTesty</title>
    <link rel="icon" type="image/png" href="{$basePath}/img/football-logo-32.png">
    <link rel="stylesheet" href="{$basePath}/css/app.css">
</head>
<body>
<header class="site-header">
    <a class="brand" n:href="Homepage:default">
        <span class="brand-mark"><img src="{$basePath}/img/football-logo.png" alt="FotbalTesty logo"></span>
        <span>FotbalTesty</span>
    </a>
    <nav>
        <a n:href="Homepage:default">Úvod</a>
        {if $currentUser->isLoggedIn()}
            <a n:href="Dashboard:default">Můj přehled</a>
            <a n:href="Sign:out">Odhlásit</a>
        {else}
            <a class="button small" n:href="Sign:in">Přihlásit</a>
        {/if}
    </nav>
</header>

{foreach $flashes as $flash}
    <div class="flash {$flash->type}">{$flash->message}</div>
{/foreach}

<main class="container">
    {include content}
</main>
<footer>FotbalTesty</footer>
</body>
</html>
