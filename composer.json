{
  "name": "fotbaltesty/modern",
  "description": "Modernized football referee testing application",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "nette/application": "3.2.*",
    "nette/bootstrap": "3.2.*",
    "nette/database": "^3.2",
    "nette/di": "3.2.*",
    "nette/forms": "3.2.*",
    "nette/http": "3.3.*",
    "nette/mail": "^4.0",
    "nette/robot-loader": "^4.0",
    "nette/security": "3.2.*",
    "nette/utils": "^4.0",
    "latte/latte": "^3.0",
    "tracy/tracy": "^2.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8080 -t public",
    "check": "@php scripts/check.php"
  }
}
