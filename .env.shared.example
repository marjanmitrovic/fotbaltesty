APP_ENV=production
APP_DEBUG=0

DB_DSN="mysql:host=YOUR_MYSQL_HOST;port=3306;dbname=YOUR_DATABASE;charset=utf8mb4"
DB_USER="YOUR_DATABASE_USER"
DB_PASSWORD="YOUR_DATABASE_PASSWORD"

# Leave empty for ordinary shared-hosting MySQL.
# Set only when the remote database requires a CA certificate.
DB_SSL_CA=
